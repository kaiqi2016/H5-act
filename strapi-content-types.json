{
  "contentTypes": {
    "activity": {
      "kind": "collectionType",
      "collectionName": "activities",
      "info": { "singularName": "activity", "pluralName": "activities", "displayName": "抽奖活动" },
      "attributes": {
        "name": { "type": "string" },
        "type": { "type": "enumeration", "enum": ["A", "B"] },
        "startDate": { "type": "date" },
        "endDate": { "type": "date" },
        "status": { "type": "enumeration", "enum": ["draft", "active", "ended"] },
        "themes": { "type": "relation", "relation": "oneToMany", "target": "api::theme.theme" }
      }
    },
    "theme": {
      "kind": "collectionType",
      "collectionName": "themes",
      "info": { "singularName": "theme", "pluralName": "themes", "displayName": "主题" },
      "attributes": {
        "name": { "type": "string" },
        "config": { "type": "json" },
        "activity": { "type": "relation", "relation": "manyToOne", "target": "api::activity.activity" }
      }
    },
    "prize": {
      "kind": "collectionType",
      "collectionName": "prizes",
      "info": { "singularName": "prize", "pluralName": "prizes", "displayName": "奖品" },
      "attributes": {
        "name": { "type": "string" },
        "probability": { "type": "decimal" },
        "quantity": { "type": "integer" },
        "icon": { "type": "string" },
        "activity": { "type": "relation", "relation": "manyToOne", "target": "api::activity.activity" }
      }
    }
  }
}